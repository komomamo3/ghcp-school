---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import Card from '../../components/Card.astro';
import { useTranslations, localizedPath } from '../../i18n';
import { heroCopy, homeFeatures } from '../../data/site';

const locale = 'en' as const;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (p: string) => `${base}${localizedPath(locale, p)}`;
const hero = heroCopy[locale];
const features = homeFeatures[locale];
const pathname = '/en/';
---

<BaseLayout pathname={pathname} locale={locale} description={t.description}>
  <Hero
    eyebrow={hero.eyebrow}
    title={hero.title}
    lead={hero.lead}
    image="https://images.unsplash.com/photo-1470770841072-f978cf4d019e?auto=format&fit=crop&w=2400&q=80"
    imageAlt="Misty mountains in Tokushima"
  >
    <a slot="cta" class="btn-ghost" href={withBase('/about/')}>{t.cta.explore}</a>
    <a slot="cta" class="btn-ghost" href={withBase('/contact/')}>{t.cta.contact}</a>
  </Hero>

  <section class="container-wide py-24">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-4">
        <SectionTitle eyebrow="Philosophy" title="From makers to founders." />
      </div>
      <div class="md:col-span-7 md:col-start-6">
        <p class="text-base leading-loose text-ink-soft">
          Kamiyama Marugoto College of Technology is a private 5-year KOSEN in Kamiyama,
          Tokushima. Over five years, students weave together engineering, design, and
          entrepreneurship, treating the small mountain town of about 5,000 people as their
          extended campus.
        </p>
        <p class="mt-6 text-sm text-ink-mute">
          This is an unofficial introduction site. For accurate, up-to-date information, please
          visit the
          <a class="link-underline" href="https://kamiyama.ac.jp/" target="_blank" rel="noopener noreferrer">official site</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-beige-50">
    <div class="container-wide py-24">
      <SectionTitle eyebrow="Highlights" title="Three lenses on the school." />
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {features.map((f) => (
          <Card eyebrow={f.eyebrow} title={f.title} body={f.body} image={f.image} href={withBase(f.href)} />
        ))}
      </div>
    </div>
  </section>

  <section class="container-wide py-24">
    <div class="border border-beige-200 p-10 md:p-16">
      <div class="grid gap-10 md:grid-cols-2 md:items-end">
        <div>
          <span class="eyebrow">Visit / Contact</span>
          <h2 class="mt-3 font-serif text-3xl leading-tight tracking-tightj md:text-4xl">
            Visit and reach out.
          </h2>
          <p class="mt-4 max-w-xl text-ink-soft">
            For school visits, press inquiries, or admissions questions, please get in touch.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 md:justify-end">
          <a class="btn-ghost" href={withBase('/access/')}>{t.nav.access}</a>
          <a class="btn-ghost" href={withBase('/contact/')}>{t.cta.contact}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
