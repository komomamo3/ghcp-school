---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';

const locale = 'en' as const;
const pathname = '/en/campus/';

const photos = [
  { src: 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1600&q=80', alt: 'Mountains and river', caption: 'A campus held by nature' },
  { src: 'https://images.unsplash.com/photo-1505691938895-1758d7feb511?auto=format&fit=crop&w=1600&q=80', alt: 'Sunlit forest', caption: 'Learning beside the forest' },
  { src: 'https://images.unsplash.com/photo-1486325212027-8081e485255e?auto=format&fit=crop&w=1600&q=80', alt: 'Warm wooden interior', caption: 'Wood-warm school buildings' },
  { src: 'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=1600&q=80', alt: 'Hands at a notebook and laptop', caption: 'Hands-on every day' },
  { src: 'https://images.unsplash.com/photo-1473773508845-188df298d2d1?auto=format&fit=crop&w=1600&q=80', alt: 'Riverside nature', caption: 'A town with clear streams' },
  { src: 'https://images.unsplash.com/photo-1504805572947-34fad45aed93?auto=format&fit=crop&w=1600&q=80', alt: 'Students gathering', caption: 'Life in the dorms' },
];
---

<BaseLayout pathname={pathname} locale={locale} title="Campus">
  <section class="container-wide pt-28 pb-12">
    <span class="eyebrow">Campus</span>
    <h1 class="mt-4 font-serif text-4xl leading-tight tracking-tightj text-ink md:text-5xl">
      The whole town is our campus.
    </h1>
    <p class="mt-6 max-w-prose text-base leading-loose text-ink-soft">
      Kamiyama is a town of about 5,000 people in Tokushima — a unique place where art and IT
      coexist with the mountains. The school buildings, dorms, town facilities and nature itself
      shape five years of learning.
    </p>
  </section>

  <section class="container-wide py-12">
    <SectionTitle eyebrow="Gallery" title="Fragments of a place" />
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {photos.map((p) => (
        <figure class="group overflow-hidden border border-beige-200">
          <div class="aspect-[4/3] overflow-hidden bg-beige-100">
            <img src={p.src} alt={p.alt} loading="lazy" decoding="async" class="h-full w-full object-cover grayscale-[25%] transition-transform duration-700 group-hover:scale-[1.04]" />
          </div>
          <figcaption class="px-4 py-3 text-xs text-ink-mute">{p.caption}</figcaption>
        </figure>
      ))}
    </div>
    <p class="mt-6 text-xs text-ink-mute">Images are illustrative — courtesy of Unsplash photographers.</p>
  </section>

  <section class="bg-beige-50">
    <div class="container-wide py-20">
      <SectionTitle eyebrow="Facilities" title="Main facilities" />
      <ul class="mt-10 grid gap-6 md:grid-cols-2">
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">Studios &amp; classrooms</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">Open spaces for making, prototyping and dialogue.</p>
        </li>
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">Dormitory</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">A residential life that becomes a second classroom.</p>
        </li>
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">Dining &amp; cafeteria</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">Local ingredients, conversations born around the table.</p>
        </li>
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">Town facilities &amp; satellite offices</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">Working with offices and workshops scattered across town.</p>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
