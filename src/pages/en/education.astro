---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';

const locale = 'en' as const;
const pathname = '/en/education/';

const years = [
  { year: 'Year 1', label: 'Foundations', body: 'Cross foundations of programming, design, English and liberal arts.' },
  { year: 'Year 2', label: 'Skills', body: 'Build implementation skills in software, hardware, and design.' },
  { year: 'Year 3', label: 'Projects', body: 'Team-based, iterative project learning from prototype to validation.' },
  { year: 'Year 4', label: 'Practice', body: 'Industry / community projects, long internships, study abroad.' },
  { year: 'Year 5', label: 'Launch', body: 'Capstone work or venture launch — ship your five years to the world.' },
];
---

<BaseLayout pathname={pathname} locale={locale} title="Education">
  <section class="container-wide pt-28 pb-16">
    <span class="eyebrow">Education</span>
    <h1 class="mt-4 font-serif text-4xl leading-tight tracking-tight text-on-surface md:text-5xl">
      Technology × Design × Entrepreneurship
    </h1>
    <p class="mt-6 max-w-prose text-base leading-loose text-on-surface-variant">
      A project-centric curriculum to develop both the power to make and the power to start —
      moving fluidly across the three areas over five years.
    </p>
  </section>

  <section class="container-wide py-16">
    <SectionTitle eyebrow="Curriculum" title="Five years, in flow" />
    <ol class="mt-12 divide-y divide-beige-200 border-y border-outline-variant">
      {years.map((y) => (
        <li class="grid gap-3 py-8 md:grid-cols-12 md:items-baseline">
          <div class="md:col-span-2">
            <p class="font-serif text-2xl text-on-surface">{y.year}</p>
            <p class="font-sans text-xs uppercase tracking-[0.05em] text-on-surface-variant">{y.label}</p>
          </div>
          <p class="md:col-span-9 md:col-start-4 text-on-surface-variant leading-relaxed">{y.body}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="bg-beige-50">
    <div class="container-wide py-20">
      <SectionTitle eyebrow="Approach" title="How we learn" />
      <div class="mt-10 grid gap-8 md:grid-cols-2">
        <div class="border border-outline-variant bg-surface-container-lowest p-8">
          <h3 class="font-serif text-xl">Project-based</h3>
          <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">
            Real problems and themes, addressed in teams through cycles of hypothesis and validation.
          </p>
        </div>
        <div class="border border-outline-variant bg-surface-container-lowest p-8">
          <h3 class="font-serif text-xl">Connected to community</h3>
          <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">
            Kamiyama's people, industries, and nature become the textbook beyond the classroom.
          </p>
        </div>
        <div class="border border-outline-variant bg-surface-container-lowest p-8">
          <h3 class="font-serif text-xl">Faculty across worlds</h3>
          <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">
            Researchers, founders, designers and engineers from the field teach side by side.
          </p>
        </div>
        <div class="border border-outline-variant bg-surface-container-lowest p-8">
          <h3 class="font-serif text-xl">Living together</h3>
          <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">
            Residential life is part of the learning — collaboration and dialogue, every day.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
