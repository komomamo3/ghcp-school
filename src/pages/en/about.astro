---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';

const locale = 'en' as const;
const pathname = '/en/about/';
---

<BaseLayout pathname={pathname} locale={locale} title="About">
  <section class="container-wide pt-28 pb-16">
    <span class="eyebrow">About</span>
    <h1 class="mt-4 font-serif text-4xl leading-tight tracking-tight text-on-surface md:text-5xl">
      About Kamiyama College
    </h1>
    <p class="mt-6 max-w-prose text-base leading-loose text-on-surface-variant">
      Opened in April 2023 in Kamiyama, Tokushima, this private KOSEN (College of Technology) is
      the first new KOSEN in Japan in 19 years. As an accredited 5-year higher-education
      institution for students after junior high school, it nurtures people who use the power of
      making to start something new.
    </p>
  </section>

  <section class="container-wide py-16">
    <SectionTitle eyebrow="Mission" title="Three areas at the core." />
    <div class="mt-12 grid gap-10 md:grid-cols-3">
      <article>
        <p class="font-sans text-xs uppercase tracking-[0.05em] text-on-surface-variant">Technology</p>
        <h3 class="mt-2 font-serif text-2xl">Technology</h3>
        <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">
          From software and AI to hardware — learning the principles that move society by
          building.
        </p>
      </article>
      <article>
        <p class="font-sans text-xs uppercase tracking-[0.05em] text-on-surface-variant">Design</p>
        <h3 class="mt-2 font-serif text-2xl">Design</h3>
        <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">
          UI/UX, graphics, products. Cultivating a sensibility that gives meaning to technology.
        </p>
      </article>
      <article>
        <p class="font-sans text-xs uppercase tracking-[0.05em] text-on-surface-variant">Entrepreneurship</p>
        <h3 class="mt-2 font-serif text-2xl">Entrepreneurship</h3>
        <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">
          From your own questions to a venture that reaches society — practiced daily with local
          partners.
        </p>
      </article>
    </div>
  </section>

  <section class="bg-beige-50">
    <div class="container-wide py-20">
      <SectionTitle eyebrow="Facts" title="School information" />
      <dl class="mt-10 grid gap-x-10 gap-y-6 md:grid-cols-2">
        <div class="border-t border-outline-variant pt-4">
          <dt class="text-xs uppercase tracking-[0.05em] text-on-surface-variant">Name</dt>
          <dd class="mt-1 text-base text-on-surface">Kamiyama Marugoto College of Technology</dd>
        </div>
        <div class="border-t border-outline-variant pt-4">
          <dt class="text-xs uppercase tracking-[0.05em] text-on-surface-variant">Location</dt>
          <dd class="mt-1 text-base text-on-surface">Kamiyama, Myozai, Tokushima, Japan</dd>
        </div>
        <div class="border-t border-outline-variant pt-4">
          <dt class="text-xs uppercase tracking-[0.05em] text-on-surface-variant">Founded</dt>
          <dd class="mt-1 text-base text-on-surface">April 2023</dd>
        </div>
        <div class="border-t border-outline-variant pt-4">
          <dt class="text-xs uppercase tracking-[0.05em] text-on-surface-variant">Program</dt>
          <dd class="mt-1 text-base text-on-surface">5-year integrated KOSEN program</dd>
        </div>
        <div class="border-t border-outline-variant pt-4">
          <dt class="text-xs uppercase tracking-[0.05em] text-on-surface-variant">Founder</dt>
          <dd class="mt-1 text-base text-on-surface">Kamiyama Gakuen Educational Foundation</dd>
        </div>
        <div class="border-t border-outline-variant pt-4">
          <dt class="text-xs uppercase tracking-[0.05em] text-on-surface-variant">Official site</dt>
          <dd class="mt-1 text-base">
            <a class="link-underline text-on-surface" href="https://kamiyama.ac.jp/" target="_blank" rel="noopener noreferrer">
              kamiyama.ac.jp →
            </a>
          </dd>
        </div>
      </dl>
      <p class="mt-8 text-xs text-on-surface-variant">
        For accurate and up-to-date information, please refer to the official site.
      </p>
    </div>
  </section>
</BaseLayout>
