---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';

const locale = 'en' as const;
const pathname = '/en/contact/';

const inquiryEmail = 'hello@example.com';
const subject = encodeURIComponent('[ghcp-school] Inquiry');
const body = encodeURIComponent(
  'Please fill in the items below and send.\n\n' +
    '― Name:\n― Affiliation:\n― Inquiry type (e.g. visit / press / admissions / other):\n― Message:\n',
);
const mailto = `mailto:${inquiryEmail}?subject=${subject}&body=${body}`;
---

<BaseLayout pathname={pathname} locale={locale} title="Contact">
  <section class="container-wide pt-28 pb-12">
    <span class="eyebrow">Contact</span>
    <h1 class="mt-4 font-serif text-4xl leading-tight tracking-tightj text-ink md:text-5xl">
      Get in touch
    </h1>
    <p class="mt-6 max-w-prose text-base leading-loose text-ink-soft">
      For inquiries about this introduction site, please reach the address below. For official
      questions about admissions or school operations, please use the contact channels on the
      <a class="link-underline" href="https://kamiyama.ac.jp/" target="_blank" rel="noopener noreferrer">official site</a>.
    </p>
  </section>

  <section class="container-wide py-12">
    <SectionTitle eyebrow="Email" title="By email" />
    <div class="mt-10 border border-beige-200 p-8 md:p-12">
      <p class="text-sm leading-relaxed text-ink-soft">
        The button below opens a new email with subject and body templates pre-filled.
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-4">
        <a class="btn-ghost" href={mailto}>Compose email →</a>
        <code class="text-sm text-ink-mute">{inquiryEmail}</code>
      </div>
      <p class="mt-6 text-xs text-ink-mute">Note: this is a sample address. Replace it before publishing.</p>
    </div>
  </section>

  <section class="bg-beige-50">
    <div class="container-wide py-20">
      <SectionTitle eyebrow="Categories" title="What you might write about" />
      <ul class="mt-10 grid gap-6 md:grid-cols-2">
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">About this site</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">Suggestions, corrections, or comments on the content.</p>
        </li>
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">Press / media</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">Quotation requests or media coverage.</p>
        </li>
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">Admissions inquiries</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">For official admissions information, please use the school's official site.</p>
        </li>
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">Other</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">Anything else — feel free to reach out.</p>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
