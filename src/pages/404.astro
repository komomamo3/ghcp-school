---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, localizedPath } from '../i18n';

const locale = 'ja' as const;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const home = `${base}${localizedPath(locale, '/')}`;
---

<BaseLayout pathname="/404/" locale={locale} title="404">
  <section class="container-wide flex min-h-[60vh] flex-col justify-center py-24">
    <span class="eyebrow">404 — Not Found</span>
    <h1 class="mt-4 font-serif text-5xl tracking-tightj text-ink md:text-6xl">
      ページが見つかりません。
    </h1>
    <p class="mt-6 max-w-prose text-ink-soft">
      お探しのページは移動・削除された可能性があります。お手数ですが、ホームから再度お探しください。
    </p>
    <div class="mt-10">
      <a class="btn-ghost" href={home}>{t.cta.backHome}</a>
    </div>
  </section>
</BaseLayout>
