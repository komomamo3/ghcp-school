---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';

const locale = 'ja' as const;
const pathname = '/campus/';

const photos = [
  {
    src: 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1600&q=80',
    alt: '山と川のある里山の風景',
    caption: '里山に抱かれたキャンパス',
  },
  {
    src: 'https://images.unsplash.com/photo-1505691938895-1758d7feb511?auto=format&fit=crop&w=1600&q=80',
    alt: '木漏れ日の差す森',
    caption: '森と隣り合う学び場',
  },
  {
    src: 'https://images.unsplash.com/photo-1486325212027-8081e485255e?auto=format&fit=crop&w=1600&q=80',
    alt: '木造の建築の内観',
    caption: '木のぬくもりのある校舎',
  },
  {
    src: 'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=1600&q=80',
    alt: 'ノートとPCで学ぶ手元',
    caption: '手を動かす日常',
  },
  {
    src: 'https://images.unsplash.com/photo-1473773508845-188df298d2d1?auto=format&fit=crop&w=1600&q=80',
    alt: '川辺の自然',
    caption: '清流が流れる町',
  },
  {
    src: 'https://images.unsplash.com/photo-1504805572947-34fad45aed93?auto=format&fit=crop&w=1600&q=80',
    alt: '集まる学生たち',
    caption: '寮での暮らし',
  },
];
---

<BaseLayout pathname={pathname} locale={locale} title="キャンパス">
  <section class="container-wide pt-28 pb-12">
    <span class="eyebrow">Campus</span>
    <h1 class="mt-4 font-serif text-4xl leading-tight tracking-tightj text-ink md:text-5xl">
      町まるごとが、キャンパス。
    </h1>
    <p class="mt-6 max-w-prose text-base leading-loose text-ink-soft">
      徳島県神山町は、人口約5,000人。森と清流に囲まれた、アートとITが共存するユニークな町です。
      校舎・寮・町の施設・自然そのものが、5年間の学びの舞台になります。
    </p>
  </section>

  <section class="container-wide py-12">
    <SectionTitle eyebrow="Gallery" title="風景の断片" />
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {photos.map((p) => (
        <figure class="group overflow-hidden border border-beige-200">
          <div class="aspect-[4/3] overflow-hidden bg-beige-100">
            <img
              src={p.src}
              alt={p.alt}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover grayscale-[25%] transition-transform duration-700 group-hover:scale-[1.04]"
            />
          </div>
          <figcaption class="px-4 py-3 text-xs text-ink-mute">{p.caption}</figcaption>
        </figure>
      ))}
    </div>
    <p class="mt-6 text-xs text-ink-mute">画像は Unsplash のフリー素材を使用したイメージです。</p>
  </section>

  <section class="bg-beige-50">
    <div class="container-wide py-20">
      <SectionTitle eyebrow="Facilities" title="主な施設" />
      <ul class="mt-10 grid gap-6 md:grid-cols-2">
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">校舎・スタジオ</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            講義室に加え、ものづくりやプロトタイピング、議論のための開かれた空間を整備。
          </p>
        </li>
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">寮 / Dormitory</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            原則として全寮制。学びと暮らしが地続きになる、もう一つの教室です。
          </p>
        </li>
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">食堂・カフェテリア</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            地域の食材を活かした食事と、自然と対話が生まれる時間。
          </p>
        </li>
        <li class="border border-beige-200 bg-paper p-8">
          <h3 class="font-serif text-xl">町の施設・サテライトオフィス</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            神山町に点在するオフィスや工房と連携し、現場での学びを実現。
          </p>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
