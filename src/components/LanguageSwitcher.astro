---
import { alternateLocalePath, useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const targetPath = alternateLocalePath(pathname, locale);
const href = `${base}${targetPath}`;
---

<a
  href={href}
  class="inline-flex items-center gap-1 rounded border border-outline-variant px-3 py-1.5 font-sans text-xs uppercase tracking-[0.05em] text-on-surface-variant transition-colors hover:border-on-surface hover:text-on-surface"
  aria-label={`Switch language to ${t.lang.switch}`}
>
  {t.lang.switch}
</a>
