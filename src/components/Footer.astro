---
import { useTranslations, localizedPath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();

function withBase(p: string) {
  return `${base}${localizedPath(locale, p)}`;
}

const navItems = [
  { key: 'about', href: '/about/' },
  { key: 'education', href: '/education/' },
  { key: 'campus', href: '/campus/' },
  { key: 'access', href: '/access/' },
  { key: 'contact', href: '/contact/' },
] as const;
---

<footer class="mt-24 border-t border-beige-200 bg-paper">
  <div class="container-wide grid gap-10 py-14 md:grid-cols-3">
    <div>
      <p class="font-serif text-lg leading-snug text-ink">{t.siteName}</p>
      <p class="mt-1 font-en text-[11px] uppercase tracking-wider2 text-ink-mute">
        Kamiyama Marugoto College of Technology
      </p>
      <p class="mt-4 max-w-sm text-sm leading-relaxed text-ink-soft">
        {t.description}
      </p>
    </div>

    <nav>
      <p class="eyebrow">Sitemap</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="link-underline text-ink-soft hover:text-ink" href={withBase('/')}>{t.nav.home}</a></li>
        {navItems.map((item) => (
          <li>
            <a class="link-underline text-ink-soft hover:text-ink" href={withBase(item.href)}>
              {t.nav[item.key]}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div>
      <p class="eyebrow">Links</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li>
          <a
            class="link-underline text-ink-soft hover:text-ink"
            href="https://kamiyama.ac.jp/"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t.footer.officialLabel} (kamiyama.ac.jp) →
          </a>
        </li>
        <li class="text-xs text-ink-mute">{t.footer.imageCredit}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-beige-200">
    <div
      class="container-wide flex flex-col gap-2 py-5 text-xs text-ink-mute md:flex-row md:items-center md:justify-between"
    >
      <p>© {year} ghcp-school. {t.footer.rights}</p>
      <p class="font-en tracking-wider2 uppercase">Kamiyama · Tokushima · Japan</p>
    </div>
  </div>
</footer>
