---
interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  href?: string;
  image?: string;
  imageAlt?: string;
}
const { eyebrow, title, body, href, image, imageAlt = '' } = Astro.props;

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group block border border-beige-200 bg-paper transition-colors',
    href && 'hover:border-ink',
  ]}
>
  {image && (
    <div class="aspect-[4/3] overflow-hidden bg-beige-100">
      <img
        src={image}
        alt={imageAlt}
        class="h-full w-full object-cover grayscale-[20%] transition-transform duration-700 group-hover:scale-[1.03]"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}
  <div class="flex flex-col gap-3 p-6">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h3 class="font-serif text-xl leading-snug text-ink">{title}</h3>
    {body && <p class="text-sm leading-relaxed text-ink-soft">{body}</p>}
    {href && (
      <span class="mt-2 font-en text-xs uppercase tracking-wider2 text-ink-mute group-hover:text-ink">
        Read more →
      </span>
    )}
  </div>
</Tag>
