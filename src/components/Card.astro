---
interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  href?: string;
  /** Label for the "read more" affordance. Defaults to English; pass a localised string from the page. */
  linkLabel?: string;
  image?: string;
  imageAlt?: string;
}
const { eyebrow, title, body, href, linkLabel = 'Read more →', image, imageAlt = '' } = Astro.props;

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group block rounded border border-outline-variant bg-surface-container-lowest shadow-subtle transition-shadow',
    href && 'hover:shadow-active',
  ]}
>
  {image && (
    <div class="aspect-[4/3] overflow-hidden rounded-t bg-surface-container-low">
      <img
        src={image}
        alt={imageAlt}
        class="h-full w-full object-cover grayscale-[20%] transition-transform duration-700 group-hover:scale-[1.03]"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}
  <div class="flex flex-col gap-3 p-6">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h3 class="font-serif text-xl leading-snug text-on-surface">{title}</h3>
    {body && <p class="text-sm leading-relaxed text-on-surface-variant">{body}</p>}
    {href && (
      <span class="mt-2 font-sans text-xs uppercase tracking-[0.05em] text-on-surface-variant group-hover:text-on-surface">
        {linkLabel}
      </span>
    )}
  </div>
</Tag>
